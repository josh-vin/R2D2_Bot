### Variables
@baseUrl = https://swgoh.plexiverse.net
@format = application/json

### Get Player Arena Data
# Used in fetch_pvp_ranks function
POST {{baseUrl}}/playerArena
Content-Type: {{format}}

{
  "payload": {
    "allyCode": "311527188"
  }
}

### Get Player Profile
POST {{baseUrl}}/player
Content-Type: {{format}}

{
  "payload": {
    "allyCode": "311527188"
  }
}

### Get Guild Info
# Used in get_guild_info function
POST {{baseUrl}}/getGuilds
Content-Type: {{format}}

{
        "payload": {
            "filterType": 4,
            "name": "Orden de Nihil",
            "startIndex": 0,
            "count": 10
        },
        "enums": false
    }

### Get Guild Members by ID
# Used in get_player_id_from_guild function
POST {{baseUrl}}/guild
Content-Type: {{format}}

{
  "payload": {
    "guildId": "F7CifF9QSaq4NmChxYhrEg",
    "includeRecentGuildActivityInfo": true
  }
}

### Get Player Info by ID
# Used in get_player_ally_code_by_id function
POST {{baseUrl}}/player
Content-Type: {{format}}

{
  "payload": {
    "playerId": "ch1sWYBXTNGoEkkqP6qD3Q"
  }
}

### Get Unit List
# Useful for character caching operations
POST {{baseUrl}}/data
Content-Type: {{format}}

{
  "payload": {
    "collection": "unitsList"
  }
}

### Get Character Definitions
# Useful for character_caching.py
POST {{baseUrl}}/data
Content-Type: {{format}}

{
  "payload": {
    "collection": "characterDefinitions"
  }
}

### Get Player's Character Inventory
# Useful for extract_inventory.py
POST {{baseUrl}}/playerArena
Content-Type: {{format}}

{
  "payload": {
    "allyCode": "311527188",
    "includeMods": true
  }
}

### Get Player's Mod Inventory
# For update_mod_data.py
POST {{baseUrl}}/playerArena
Content-Type: {{format}}

{
  "payload": {
    "allyCode": "311527188",
    "includeMods": true
  }
}

### Get Guild Raid Information
# For guild raid tracking
POST {{baseUrl}}/guild
Content-Type: {{format}}

{
  "payload": {
    "guildId": "YOUR_GUILD_ID",
    "includeRecentRaidResult": true
  }
}

